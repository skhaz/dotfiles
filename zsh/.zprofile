source ~/.orbstack/shell/init.zsh 2>/dev/null || :

export PIP_REQUIRE_VIRTUALENV=true

alias k=kubectl

alias backup=~/Documents/backup.sh

alias vim=nvim

alias psql=/Applications/Postgres.app/Contents/Versions/18/bin/psql

export EDITOR="nvim"

alias matrix=cmatrix

export PATH="/opt/workspace/wippy/runtime/dist:$PATH"
