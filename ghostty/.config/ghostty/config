command = /opt/homebrew/bin/mise exec -- tmux new-session -A -D -s default
working-directory = /opt/workspace

maximize = true
window-decoration = false

theme = Atom One Dark

font-family = Menlo
font-size = 14

confirm-close-surface = false

keybind = super+k=text:\x0c
keybind = super+n=text:\x01c

keybind = super+digit_1=text:\x1b\x31
keybind = super+digit_2=text:\x1b\x32
keybind = super+digit_3=text:\x1b\x33
keybind = super+digit_4=text:\x1b\x34
keybind = super+digit_5=text:\x1b\x35
keybind = super+digit_6=text:\x1b\x36
keybind = super+digit_7=text:\x1b\x37
keybind = super+digit_8=text:\x1b\x38
keybind = super+digit_9=text:\x1b\x39

macos-option-as-alt = true
mouse-hide-while-typing = true
macos-icon = custom
macos-custom-icon = ~/.config/ghostty/catppuccin-mocha.icns
